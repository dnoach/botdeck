# Copy this file to .env and fill in your values
# cp .env.example .env

# Path to your OpenClaw data directory on the VPS host
OPENCLAW_ROOT=/root/.openclaw

# Random secret for signing session cookies — generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-random-string

# Password to log in to the BotDeck dashboard
DASHBOARD_PASSWORD=change-me-to-a-strong-password

# Tailscale auth key — generate at https://login.tailscale.com/admin/settings/keys
# Use a "Reusable" auth key
TS_AUTHKEY=tskey-auth-xxxxxxxxxx

# OpenClaw gateway — used by the chat feature
# Set this to http://<docker-bridge-gateway-ip>:3002 after running the chat proxy
# Find your bridge IP with: docker network inspect botdeck_botdeck-net | grep Gateway
OPENCLAW_GATEWAY_URL=http://<your-bridge-ip>:3002
OPENCLAW_GATEWAY_TOKEN=your-gateway-token-here
